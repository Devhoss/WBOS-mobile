# WBOS Mobile Environment Configuration
# Copy this file to .env.development, .env.homelab, or .env.production

# App Environment: development | homelab | production
EXPO_PUBLIC_APP_ENV=development

# ── Development ────────────────────────────────────────────
# Local LAN: WBOS Web on 192.168.100.36:3005
# Uses HTTP + cleartext (android:usesCleartextTraffic enabled for dev only)
#   EXPO_PUBLIC_API_URL=http://192.168.100.36:3005
#   EXPO_PUBLIC_AUTH_URL=http://192.168.100.36:3005

# ── Homelab ────────────────────────────────────────────────
# Internal domain via Pi-hole (HTTPS, requires working local DNS)
#   EXPO_PUBLIC_API_URL=https://wbos.home.lab
#   EXPO_PUBLIC_AUTH_URL=https://wbos.home.lab

# ── Production ─────────────────────────────────────────────
# Real domain with public DNS + Let's Encrypt (HTTPS only)
#   EXPO_PUBLIC_API_URL=https://api.wbos.app
#   EXPO_PUBLIC_AUTH_URL=https://api.wbos.app
